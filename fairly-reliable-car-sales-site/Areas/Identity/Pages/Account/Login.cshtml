@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">@ViewData["Title"]</h1>
        <p class="lead text-light">Access your account to explore all our features.</p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <div class="row justify-content-center">
        <!-- Login Form -->
        <div class="col-md-6">
            <div class="p-4 rounded bg-dark text-white shadow-lg">
                <form id="account" method="post">
                    <h2 class="text-center mb-4">Log in</h2>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <!-- Email -->
                    <div class="form-group mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="e.g. name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-group mb-3">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <input asp-for="Input.Password" type="password" class="form-control" autocomplete="current-password" placeholder="Enter your password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Remember Me -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
                    </div>

                    <!-- Submit Button -->
                    <button id="login-submit" type="submit" class="btn btn-outline-light w-100" style="border-color: #c0392b; color: #c0392b;">Log in</button>

                    <!-- Links -->
                    <div class="mt-3 text-center">
                        <p><a id="forgot-password" asp-page="./ForgotPassword" class="text-light">Forgot your password?</a></p>
                        <p><a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-light">Register as a new user</a></p>
                        <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="text-light">Resend email confirmation</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
