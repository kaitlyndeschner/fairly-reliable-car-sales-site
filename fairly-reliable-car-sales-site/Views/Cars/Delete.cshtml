@model FairlyReliableCarSalesSite.Models.Car

@{
    ViewData["Title"] = "Delete";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Delete Car</h1>
        <p class="lead text-light">
            Are you sure you want to delete this car from the inventory?
        </p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Car Details -->
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="p-4 rounded bg-dark text-white shadow">
                <h4 class="fw-bold text-center mb-4">Car Details</h4>
                <dl class="row">
                    <dt class="col-sm-4">Year</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Year)</dd>

                    <dt class="col-sm-4">Make</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Make)</dd>

                    <dt class="col-sm-4">Model</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Model)</dd>

                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Price)</dd>

                    <dt class="col-sm-4">Details</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Details)</dd>

                    <!-- Display the current image -->
                    <dt class="col-sm-4">Current Image</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Url.Content(Model.ImageUrl)" alt="Car Image" class="img-fluid rounded shadow" style="max-width: 100%; height: auto;" />
                        }
                        else
                        {
                            <p class="text-light">No image available.</p>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation -->
    <div class="text-center mt-4">
        <form asp-action="Delete" class="d-inline-block">
            <input type="hidden" asp-for="CarId" />
            <input type="submit" value="Delete" class="btn delete-button" />
        </form>
        <a asp-action="Index" class="btn back-to-list-button ms-2">Back to List</a>
    </div>

