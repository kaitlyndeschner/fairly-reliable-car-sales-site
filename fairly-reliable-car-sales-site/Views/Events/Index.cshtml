@model IEnumerable<FairlyReliableCarSalesSite.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container my-5">
    <!-- Page Header -->
    <div class="text-center mb-4">
        <h1 class="display-5 fw-bold text-white">Events</h1>
        <p class="lead text-light">Browse all upcoming and past events at Fairly Reliable Car Sales.</p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Create New Event Button -->
    <div class="text-center mb-4">
        <a asp-action="Create" class="btn btn-outline-light btn-lg">Create New Event</a>
    </div>

    <!-- Events Table -->
    <div class="bg-dark text-white p-4 rounded shadow">
        <table class="table table-dark table-hover table-striped align-middle">
            <thead class="table-light text-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().Title)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Date)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Details)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Title)</td>
                            <td>@item.Date.ToString("dd MMMM yyyy")</td>
                            <td>@Html.DisplayFor(modelItem => item.Details)</td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-light btn-sm me-2">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm me-2">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No events available. Add a new event using the button above.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
