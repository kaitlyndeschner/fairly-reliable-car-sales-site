@model FairlyReliableCarSalesSite.Models.Enquiry

@{
    ViewData["Title"] = "Delete";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Delete Enquiry</h1>
        <p class="lead text-light">
            Are you sure you want to delete this enquiry from the records?
        </p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Enquiry Details -->
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="p-4 rounded bg-dark text-white shadow">
                <h4 class="fw-bold text-center mb-4">Enquiry Details</h4>
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Name)</dd>

                    <dt class="col-sm-4">Phone Number</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.PhoneNumber)</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Email)</dd>

                    <dt class="col-sm-4">Message</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Message)</dd>

                    <dt class="col-sm-4">Date Submitted</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.DateSubmitted)</dd>

                    <dt class="col-sm-4">Car</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Car.CarId)</dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation -->
    <div class="text-center mt-4">
        <form asp-action="Delete" class="d-inline-block">
            <input type="hidden" asp-for="EnquiryId" />
            <input type="submit" value="Delete" class="btn delete-button" />
        </form>
        <a asp-action="Index" class="btn back-to-list-button ms-2">Back to List</a>
    </div>
