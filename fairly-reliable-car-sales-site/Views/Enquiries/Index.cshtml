@model IEnumerable<FairlyReliableCarSalesSite.Models.Enquiry>

@{
    ViewData["Title"] = "Enquiries";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 fw-bold text-white">Enquiries</h1>
        <a asp-action="Create" class="btn btn-outline-light btn-lg" style="border-color: #c0392b; color: #c0392b;">Create New</a>
    </div>

    <!-- Helpful Links Section -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow" style="height: 100%;">
                <img src="/images/contactus.jpg" class="card-img-top" alt="Contact Us" style="height: 200px; object-fit: cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-white">Need Help?</h5>
                    <p class="card-text">Visit our Contact Us page for direct assistance with your enquiry.</p>
                    <a asp-action="ContactUs" asp-controller="Home" class="btn btn-outline-light mt-auto" style="border-color: #c0392b; color: #c0392b;">Contact Us</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow" style="height: 100%;">
                <img src="/images/viewcars.jpg" class="card-img-top" alt="Car Listings" style="height: 200px; object-fit: cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-white">Explore Cars</h5>
                    <p class="card-text">Check out our car listings to find the right car for your needs.</p>
                    <a asp-action="Index" asp-controller="Cars" class="btn btn-outline-light mt-auto" style="border-color: #c0392b; color: #c0392b;">View Cars</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow" style="height: 100%;">
                <img src="/images/services.jpg" class="card-img-top" alt="Services" style="height: 200px; object-fit: cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title text-white">Services</h5>
                    <p class="card-text">Learn more about the services we offer to keep your car in top condition.</p>
                    <a asp-action="Services" asp-controller="Home" class="btn btn-outline-light mt-auto" style="border-color: #c0392b; color: #c0392b;">View Services</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Search Enquiries Dropdown -->
    <div class="dropdown mb-4">
        <button class="btn btn-outline-light dropdown-toggle w-100" type="button" id="searchEnquiriesDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-color: #c0392b; color: #c0392b;">
            Search Enquiries
        </button>
        <div class="dropdown-menu p-4 shadow-lg" aria-labelledby="searchEnquiriesDropdown" style="background-color: #2c3e50; color: white;">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="searchName" class="form-label text-white">Name</label>
                    <input type="text" name="searchName" class="form-control" placeholder="Enter name" value="@ViewData["searchName"]" />
                </div>
                <div class="col-md-3">
                    <label for="searchEmail" class="form-label text-white">Email</label>
                    <input type="text" name="searchEmail" class="form-control" placeholder="Enter email" value="@ViewData["searchEmail"]" />
                </div>
                <div class="col-md-3">
                    <label for="searchPhone" class="form-label text-white">Phone</label>
                    <input type="text" name="searchPhone" class="form-control" placeholder="Enter phone number" value="@ViewData["searchPhone"]" />
                </div>
                <div class="col-md-3">
                    <label for="searchCarId" class="form-label text-white">Car ID</label>
                    <input type="number" name="searchCarId" class="form-control" placeholder="Enter Car ID" value="@ViewData["searchCarId"]" />
                </div>
                <div class="col-md-12 text-end mt-3">
                    <button type="submit" class="btn btn-outline-light" style="border-color: #c0392b; color: #c0392b;">Search</button>
                    <a asp-action="Index" class="btn btn-outline-light" style="border-color: white; color: white;">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Enquiry List Dropdown -->
    <div class="dropdown">
        <button class="btn btn-outline-light dropdown-toggle w-100" type="button" id="viewEnquiriesDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-color: #c0392b; color: #c0392b;">
            View Enquiries
        </button>
        <div class="dropdown-menu p-3 shadow-lg" aria-labelledby="viewEnquiriesDropdown" style="background-color: #2c3e50; color: white;">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #2c3e50; color: white;">
                    <tr>
                        <th>Name</th>
                        <th>Phone Number</th>
                        <th>Email</th>
                        <th>Message</th>
                        <th>Date Submitted</th>
                        <th>Car ID</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-secondary">No enquiries found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                                <td>@Html.DisplayFor(modelItem => item.Message)</td>
                                <td>@Html.DisplayFor(modelItem => item.DateSubmitted)</td>
                                <td>@(item.CarId.HasValue ? item.CarId.ToString() : "N/A")</td>
                                <td class="text-center">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.EnquiryId" class="btn btn-outline-light btn-sm" style="border-color: grey; color: grey;">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.EnquiryId" class="btn btn-outline-light btn-sm" style="border-color: #c0392b; color: #c0392b;">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
