@{
    ViewData["Title"] = "Services";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Our Services</h1>
        <p class="lead text-light">
            Discover how Fairly Reliable Car Sales can help you maintain and enhance your vehicle.
        </p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Services Section -->
    <div class="row text-center mb-5">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/finance.jpg" alt="Financing" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">Financing Options</h5>
                    <p class="card-text">
                        Flexible financing solutions to make your dream car a reality.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#financingDetails" aria-expanded="false" aria-controls="financingDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="financingDetails">
                        <p>
                            Competitive rates starting at 3.5% APR. We’ll work with you to find a plan that fits your budget and lifestyle.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/mot.jpg" alt="MOT Servicing" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">MOT Servicing</h5>
                    <p class="card-text">
                        Comprehensive inspections to ensure your vehicle is roadworthy.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#motDetails" aria-expanded="false" aria-controls="motDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="motDetails">
                        <p>
                            Pricing starts at £40. Includes a full inspection of brakes, lights, suspension, and other key components.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/cardiag.jpg" alt="Diagnostics" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">Vehicle Diagnostics</h5>
                    <p class="card-text">
                        Advanced diagnostic tools for quick and reliable issue detection.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#diagnosticsDetails" aria-expanded="false" aria-controls="diagnosticsDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="diagnosticsDetails">
                        <p>
                            Diagnostic services start at £50. We identify engine, transmission, and electrical issues efficiently.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/carrepair.jpg" alt="Repairs" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">Repairs & Maintenance</h5>
                    <p class="card-text">
                        Keep your vehicle in top condition with our expert repairs.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#repairsDetails" aria-expanded="false" aria-controls="repairsDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="repairsDetails">
                        <p>
                            Our certified technicians provide a full range of repairs and maintenance services:
                        </p>
                        <ul class="text-light text-start">
                            <li>Oil Change: £30 - £50 (depending on vehicle type)</li>
                            <li>Brake Pads Replacement: £80 - £120</li>
                            <li>Battery Replacement: £90 - £150</li>
                            <li>Suspension Repairs: Starting at £150</li>
                            <li>Air Conditioning Service: £60</li>
                            <li>Timing Belt Replacement: £250 - £400</li>
                            <li>Engine Repairs: Starting at £300</li>
                            <li>Tyre Replacement: £50 - £100 per tyre</li>
                        </ul>
                        <p>
                            Contact us for a customized quote or to book an appointment.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/carsalesman1.jpg" alt="Warranty" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">Warranty Options</h5>
                    <p class="card-text">
                        Drive confidently with our comprehensive warranty plans.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#warrantyDetails" aria-expanded="false" aria-controls="warrantyDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="warrantyDetails">
                        <p>
                            We offer extended warranty plans to cover unexpected repairs and ensure peace of mind:
                        </p>
                        <ul class="text-light text-start">
                            <li><strong>Basic Warranty (1 Year): £199</strong> - Covers engine and transmission.</li>
                            <li><strong>Standard Warranty (2 Years): £349</strong> - Includes engine, transmission, and drivetrain components.</li>
                            <li><strong>Comprehensive Warranty (3 Years): £499</strong> - Covers all major components, including electrical systems and air conditioning.</li>
                            <li><strong>Roadside Assistance Add-On:</strong> £50/year - Includes 24/7 towing, flat tyre repair, and emergency fuel delivery.</li>
                        </ul>
                        <p>
                            All warranties include access to our certified technicians and genuine replacement parts.
                        </p>
                        <p>
                            Contact us for more information or to customize a plan for your needs.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow h-100" style="background-color: #2c3e50; color: white;">
                <img src="/images/sale.jpg" alt="Special Offers" class="card-img-top rounded-top" style="max-height: 200px; object-fit: cover;">
                <div class="card-body">
                    <h5 class="card-title fw-bold" style="color: #c0392b;">Special Offers</h5>
                    <p class="card-text">
                        Save big with our promotions and discounts on services.
                    </p>
                    <button class="btn btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#specialOffersDetails" aria-expanded="false" aria-controls="specialOffersDetails">
                        Learn More
                    </button>
                    <div class="collapse mt-3" id="specialOffersDetails">
                        <p>
                            Seasonal discounts up to 20% off on selected services. Contact us for details!
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
