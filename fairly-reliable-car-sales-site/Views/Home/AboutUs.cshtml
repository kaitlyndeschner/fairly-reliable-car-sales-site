@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">About Fairly Reliable Car Sales</h1>
        <p class="lead text-light">Your trusted partner for quality cars, exceptional service, and community commitment.</p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Main Content Section -->
    <div class="row align-items-center mb-5">
        <!-- Left Column -->
        <div class="col-md-8 d-flex flex-column justify-content-between" style="min-height: 100%; max-height: 400px;">
            <div>
                <h2 class="fw-bold text-white mb-4">Who We Are</h2>
                <p class="text-light">
                    At <strong>Fairly Reliable Car Sales</strong>, we’ve spent years helping customers across Northern Ireland and beyond find their ideal vehicles.
                    Whether you’re looking for a practical family car, a stylish ride, or expert vehicle servicing, we’re here to make it happen.
                </p>
                <p class="text-light">
                    Our commitment to excellence extends to every aspect of our business, from the moment you step into our showroom to the support we offer long after you’ve driven away in your new car.
                    Our knowledgeable and friendly team is always on hand to provide expert advice and assistance tailored to your needs.
                </p>
            </div>

            <div>
                <h3 class="fw-bold text-white mt-4">Our Mission</h3>
                <p class="text-light">
                    Our mission is simple: to provide reliable, high-quality cars while ensuring a stress-free, enjoyable purchasing experience.
                    We believe in creating long-lasting relationships with our customers, built on trust, transparency, and a shared love of cars.
                </p>
            </div>
        </div>

        <!-- Right Column with Image -->
        <div class="col-md-4 text-center">
            <img src="/images/Fairly Reliable.jpg" alt="Fairly Reliable Logo" class="img-fluid rounded shadow" style="border: 2px solid #c0392b; max-height: 400px;">
        </div>
    </div>

    <!-- Managing Director Section -->
    <div class="row align-items-center mb-5">
        <!-- Image Section -->
        <div class="col-md-4 text-center">
            <img src="/images/billprofitt1.jpg" alt="Bill Profitt" class="img-fluid rounded shadow" style="border: 2px solid #c0392b;">
        </div>
        <!-- Description Section -->
        <div class="col-md-8">
            <h2 class="fw-bold text-white mb-4">Meet Our Managing Director</h2>
            <p class="text-light">
                <strong>Bill Profitt</strong>, our Managing Director, has been the driving force behind <strong>Fairly Reliable Car Sales</strong> for over a decade.
                With a passion for cars and an unwavering commitment to customer satisfaction, Bill has built the dealership into one of Northern Ireland’s most trusted names.
            </p>
            <p class="text-light">
                Bill's philosophy is simple: "Treat every customer like family." His hands-on approach and deep understanding of the automotive industry
                ensure that every vehicle meets the highest standards of quality and reliability.
            </p>
            <p class="text-light">
                Outside of work, Bill enjoys supporting local community events and spending time with his family. He actively participates in local charity events,
                fundraisers, and educational programs to give back to the community that has supported Fairly Reliable Car Sales over the years.
            </p>
            <p class="text-light">
                With over 20 years of experience in the automotive industry, Bill has gained recognition for his leadership, vision, and ability to build strong
                relationships with both customers and business partners. His commitment to excellence has earned Fairly Reliable Car Sales numerous accolades,
                including the "Best Dealership" award in County Tyrone for three consecutive years.
            </p>
            <p class="text-light">
                Bill’s team shares his dedication to providing an unparalleled car-buying experience, ensuring that every customer leaves satisfied and confident
                in their purchase. Visit us today to see Bill and his team in action!
            </p>
        </div>
    </div>

    <!-- Car Makes and Models Section -->
    <div class="mb-5">
        <h3 class="fw-bold text-white text-center mb-4">Car Makes and Models We Offer</h3>
        <p class="text-light text-center">Explore a wide range of trusted car brands, including the most popular models in Northern Ireland.</p>
        <div class="row g-4">
            <!-- Ford -->
            <div class="col-md-4 text-center">
                <img src="/images/fordlogo.jpg" alt="Ford Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Ford</h5>
                <p class="text-light">Fiesta, Focus, Mondeo, Kuga</p>
            </div>
            <!-- Vauxhall -->
            <div class="col-md-4 text-center">
                <img src="/images/vauxhalllogo.jpg" alt="Vauxhall Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Vauxhall</h5>
                <p class="text-light">Corsa, Astra, Insignia, Mokka</p>
            </div>
            <!-- Toyota -->
            <div class="col-md-4 text-center">
                <img src="/images/mercedeslogo.jpg" alt="Mercedes Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Mercedes-Benz</h5>
                <p class="text-light">C-Class, GLC, S-Class, EQE</p>
            </div>
            <!-- Nissan -->
            <div class="col-md-4 text-center">
                <img src="/images/nissanlogo.jpg" alt="Nissan Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Nissan</h5>
                <p class="text-light">Micra, Qashqai, Juke, X-Trail</p>
            </div>
            <!-- BMW -->
            <div class="col-md-4 text-center">
                <img src="/images/bmwlogo.jpg" alt="BMW Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">BMW</h5>
                <p class="text-light">1 Series, 3 Series, 5 Series, X5</p>
            </div>
            <!-- Audi -->
            <div class="col-md-4 text-center">
                <img src="/images/audilogo.jpg" alt="Audi Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Audi</h5>
                <p class="text-light">A3, A4, Q3, Q5</p>
            </div>
            <!-- Honda -->
            <div class="col-md-4 text-center">
                <img src="/images/hondalogo.jpg" alt="Honda Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Honda</h5>
                <p class="text-light">Civic, Accord, CR-V, Jazz</p>
            </div>
            <!-- Tesla -->
            <div class="col-md-4 text-center">
                <img src="/images/teslalogo.jpg" alt="Tesla Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Tesla</h5>
                <p class="text-light">Model S, Model 3, Model X, Model Y</p>
            </div>
            <!-- Kia -->
            <div class="col-md-4 text-center">
                <img src="/images/kialogo.jpg" alt="Kia Logo" class="img-fluid mb-2" style="max-height: 100px;">
                <h5 class="text-white">Kia</h5>
                <p class="text-light">Sportage, Sorento, Picanto, Rio</p>
            </div>
        </div>
    </div>

    <!-- Call-to-Action Section -->
    <div class="text-center py-5 mt-5 rounded shadow" style="background-color: #c0392b; color: white;">
        <h2 class="fw-bold">Visit Us Today!</h2>
        <p>Whether you’re buying, selling, or servicing your car, Fairly Reliable Car Sales is your trusted partner. Stop by our dealership or explore our selection online.</p>
        <a href="/Cars" class="btn btn-light btn-lg">View Our Cars</a>
    </div>
</div>
