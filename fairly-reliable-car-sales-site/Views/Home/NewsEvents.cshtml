@{
    ViewData["Title"] = "News & Events";
}

<div class="container my-5">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">News & Events</h1>
        <p class="lead text-light">
            Stay informed about the latest updates, offers, and opportunities at Fairly Reliable Car Sales.
        </p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Latest News Section -->
    <div class="mb-5">
        <h2 class="text-center fw-bold text-white">Latest News</h2>
        <p class="text-center text-light mb-4">Discover our latest updates, achievements, and community contributions.</p>
        <div class="row g-4">
            <!-- News Item 1 -->
            <div class="col-md-4">
                <div class="card bg-dark text-white shadow-sm h-100">
                    <img src="/images/kcentre.jpg" class="card-img-top fixed-img" alt="Community Fundraiser">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Community Fundraiser</h5>
                        <p class="card-text">We raised £10,000 to support local charities during our annual fundraiser event.</p>
                        <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#news-details-1" aria-expanded="false" aria-controls="news-details-1">
                            Read More
                        </button>
                        <div class="collapse mt-3" id="news-details-1">
                            <p>Our annual fundraiser was a resounding success, featuring live music by local bands, delicious food from regional vendors, and an exciting charity auction. Highlights included rare collectibles and gift baskets donated by community businesses. These funds will directly benefit local charities focused on education, child welfare, and community empowerment.</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- News Item 2 -->
            <div class="col-md-4">
                <div class="card bg-dark text-white shadow-sm h-100">
                    <img src="/images/showroom.jpg" class="card-img-top fixed-img" alt="New Showroom Opening">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">New Showroom Opening</h5>
                        <p class="card-text">Join us for the grand opening of our state-of-the-art showroom in Strabane.</p>
                        <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#news-details-2" aria-expanded="false" aria-controls="news-details-2">
                            Read More
                        </button>
                        <div class="collapse mt-3" id="news-details-2">
                            <p>Our new Strabane showroom offers an enhanced experience for our customers. The sleek design includes modern displays for our latest vehicle models, a luxurious lounge area with complimentary refreshments, and interactive digital tools to customize your dream car. Join us on opening day for guided tours, exclusive offers, and a chance to win a grand prize.</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- News Item 3 -->
            <div class="col-md-4">
                <div class="card bg-dark text-white shadow-sm h-100">
                    <img src="/images/contactus.jpg" class="card-img-top fixed-img" alt="Customer Appreciation Event">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">Customer Appreciation Day</h5>
                        <p class="card-text">Join us for a day of fun, food, and prizes as we celebrate our amazing customers!</p>
                        <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#news-details-3" aria-expanded="false" aria-controls="news-details-3">
                            Read More
                        </button>
                        <div class="collapse mt-3" id="news-details-3">
                            <p>As a token of gratitude, we’re hosting an unforgettable Customer Appreciation Day! Activities include a kids’ corner with face painting, games, and a bouncy castle, while adults can enjoy live music, a barbecue, and special discounts on select models. Don’t miss the grand raffle, where one lucky winner will receive a year of free car servicing!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5"></div> <!-- Extra margin -->
        <!-- Special Offers Section -->
        <div class="mb-5">
            <h2 class="text-center fw-bold text-white">Special Offers</h2>
            <p class="text-center text-light mb-4">Take advantage of these limited-time deals and discounts.</p>
            <div class="row g-4">
                <!-- Offer 1 -->
                <div class="col-md-6">
                    <div class="card bg-dark text-white shadow-sm h-100">
                        <img src="/images/sale2.jpg" class="card-img-top fixed-img" alt="Special Offer 1">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Up to 20% Off Selected Cars</h5>
                            <p class="card-text">Save big on a wide selection of vehicles this month. Offer ends soon!</p>
                            <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#offer-details-1" aria-expanded="false" aria-controls="offer-details-1">
                                View Offers
                            </button>
                            <div class="collapse mt-3" id="offer-details-1">
                                <ul>
                                    <li><strong>Compact Cars:</strong> Up to 15% off.</li>
                                    <li><strong>SUVs:</strong> Up to 20% off selected models.</li>
                                    <li><strong>Luxury Vehicles:</strong> Save £3,000 on top brands.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Offer 2 -->
                <div class="col-md-6">
                    <div class="card bg-dark text-white shadow-sm h-100">
                        <img src="/images/oilchange.jpg" class="card-img-top fixed-img" alt="Special Offer 2">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Complimentary Oil Change</h5>
                            <p class="card-text">Get a free oil change with every major car service this month!</p>
                            <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#offer-details-2" aria-expanded="false" aria-controls="offer-details-2">
                                View Details
                            </button>
                            <div class="collapse mt-3" id="offer-details-2">
                                <p>Keep your vehicle in top shape with this limited-time offer. Every major service includes a complimentary oil change using high-quality synthetic oil. Our expert technicians will also perform a free multi-point inspection to ensure your car runs smoothly for miles to come.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <!-- Job Postings Section -->
        <div class="mb-5">
            <h2 class="text-center fw-bold text-white">Job Opportunities</h2>
            <p class="text-center text-light mb-4">Join our team and help us deliver exceptional service.</p>
            <div class="row g-4">
                <!-- Job 1 -->
                <div class="col-md-4">
                    <div class="card bg-dark text-white shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Sales Associate</h5>
                            <p class="card-text">We're looking for passionate individuals who excel in customer engagement and sales.</p>
                            <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#apply-sales" aria-expanded="false" aria-controls="apply-sales">
                                Apply Now
                            </button>
                            <div class="collapse mt-3" id="apply-sales">
                                <p>As a Sales Associate, you’ll work closely with customers to help them find the perfect vehicle, provide product knowledge, and assist with financing options. Training is provided, and experience in retail or automotive sales is a plus.</p>
                                <p>To apply, please send your CV and cover letter to careers@frcs.co.uk.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Job 2 -->
                <div class="col-md-4">
                    <div class="card bg-dark text-white shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Mechanic</h5>
                            <p class="card-text">Join our team of skilled mechanics to provide top-tier vehicle maintenance and repair.</p>
                            <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#apply-mechanic" aria-expanded="false" aria-controls="apply-mechanic">
                                Apply Now
                            </button>
                            <div class="collapse mt-3" id="apply-mechanic">
                                <p>We offer competitive salaries, ongoing training opportunities, and a supportive environment. Responsibilities include diagnosing and repairing vehicles, conducting regular maintenance checks, and ensuring customer satisfaction through high-quality work.</p>
                                <p>To apply, please send your CV and cover letter to careers@frcs.co.uk.</p>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Job 3 -->
                <div class="col-md-4">
                    <div class="card bg-dark text-white shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">Customer Support Specialist</h5>
                            <p class="card-text">Provide outstanding support and assistance to our customers.</p>
                            <button class="btn btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#apply-support" aria-expanded="false" aria-controls="apply-support">
                                Apply Now
                            </button>
                            <div class="collapse mt-3" id="apply-support">
                                <p>This role involves managing customer communication via phone, email, and in-person. You’ll resolve inquiries, coordinate service appointments, and contribute to a smooth customer journey. Strong interpersonal skills and a friendly demeanor are essential.</p>
                                <p>To apply, please send your CV and cover letter to careers@frcs.co.uk.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
