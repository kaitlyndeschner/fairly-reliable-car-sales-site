@{
    ViewData["Title"] = "Home Page";
}

<div class="container my-5">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Welcome to Fairly Reliable Car Sales</h1>
        <p class="lead text-light">Northern Ireland's trusted source for reliable cars at unbeatable prices.</p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Carousel Section -->
    <div class="carousel slide mb-5 shadow rounded overflow-hidden" id="carouselExample" data-bs-ride="carousel" data-bs-interval="3000">
        <style>
            /* Custom Styles for Carousel Indicators */
            #carouselExample .carousel-indicators button {
                background-color: rgba(52, 58, 64, 0.7); /* Semi-transparent dark grey */
            }

            #carouselExample .carousel-indicators .active {
                background-color: #343a40; /* Solid dark grey for active indicator */
            }

            #carouselExample .carousel-indicators button:hover {
                background-color: #c0392b; /* Red hover for indicators */
            }
        </style>
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="2" aria-label="Slide 3"></button>
            <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="3" aria-label="Slide 4"></button>
            <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="4" aria-label="Slide 5"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/Fairly Reliable.jpg" alt="Logo" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="/images/blackwhitecars.jpg.jpg" alt="Cars 1" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="/images/carsoutside.jpg" alt="Cars 2" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="/images/whitecar1.jpg" alt="Cars 3" class="d-block w-100">
            </div>
            <div class="carousel-item">
                <img src="/images/carsinside.jpg" alt="Cars 4" class="d-block w-100">
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExample" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <div style="display: flex; justify-content: center; align-items: center; margin: 40px 0;">
        <a href="/Cars" class="btn btn-outline-light btn-lg" style="border-color: #c0392b; color: #c0392b;">View Our Cars</a>
    </div>

    <!-- Features Section -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow-sm border-0 h-100">
                <div class="card-body">
                    <i class="fas fa-car fs-1 text-info mb-3"></i>
                    <h5 class="card-title fw-bold">Wide Range of Cars</h5>
                    <p class="card-text">From compact cars to luxury sedans, we have something for everyone.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow-sm border-0 h-100">
                <div class="card-body">
                    <i class="fas fa-tag fs-1 text-warning mb-3"></i>
                    <h5 class="card-title fw-bold">Affordable Prices</h5>
                    <p class="card-text">Quality cars at prices that won’t break the bank.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white shadow-sm border-0 h-100">
                <div class="card-body">
                    <i class="fas fa-thumbs-up fs-1 text-success mb-3"></i>
                    <h5 class="card-title fw-bold">Trusted Service</h5>
                    <p class="card-text">Over 10 years of reliable customer service and support.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- About Section -->
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <img src="/images/cars1.jpg" class="img-fluid rounded shadow" alt="About Us">
        </div>
        <div class="col-md-6">
            <h2 class="fw-bold text-white">About Fairly Reliable Car Sales</h2>
            <p class="text-light">
                At Fairly Reliable Car Sales, we pride ourselves on providing high-quality vehicles to our customers across Northern Ireland. Our extensive inventory includes everything from economical hatchbacks to family-friendly SUVs and luxury sedans. Visit us to find your next car!
            </p>
            <a href="/Home/AboutUs" class="btn btn-outline-light" style="border-color: #c0392b; color: #c0392b;">Learn More</a>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="row text-center">
        <div class="col-md-12">
            <h2 class="fw-bold text-white mb-4">Get in Touch</h2>
            <p class="lead text-light">Have questions? Need help finding the perfect car? Contact us today!</p>
            <a href="/Home/ContactUs" class="btn btn-outline-light btn-lg" style="border-color: #c0392b; color: #c0392b;">Contact Us</a>
        </div>
    </div>
</div>
