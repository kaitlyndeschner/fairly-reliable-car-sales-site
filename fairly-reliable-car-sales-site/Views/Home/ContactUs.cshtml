@{
    ViewData["Title"] = "Contact Us";
}

<div class="container my-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-white">Contact Us</h1>
        <p class="lead text-light">
            Get in touch with Fairly Reliable Car Sales. We're here to help with all your questions and inquiries.
        </p>
        <hr style="border: 1px solid #c0392b; width: 50%; margin: auto;">
    </div>

    <!-- Contact Information and Enquiry Form -->
    <div class="row">
        <!-- Contact Information Section -->
        <div class="col-md-6">
            <div class="p-4 bg-dark text-white rounded shadow h-100" style="border: 2px solid #c0392b;">
                <h2 class="fw-bold mb-4 text-white">Get in Touch!</h2>
                <div class="mb-4">
                    <p><strong>Address:</strong></p>
                    <p style="color: #c0392b;">Orchard Road Industrial Estate</p>
                    <p style="color: #c0392b;">Orchard Rd</p>
                    <p style="color: #c0392b;">Strabane</p>
                    <p style="color: #c0392b;">BT82 9FR</p>
                    <p style="color: #c0392b;">Northern Ireland</p>
                </div>
                <div class="mb-4">
                    <p><strong>Phone:</strong></p>
                    <p><a href="tel:+447512345678" style="color: #c0392b;">+44 75 1234 5678</a></p>
                </div>
                <div>
                    <p><strong>Email:</strong></p>
                    <p><a href="mailto:info@frsc.co.uk" style="color: #c0392b;">info@frsc.co.uk</a></p>
                </div>
            </div>
        </div>

        <!-- Enquiry Form Section -->
        <div class="col-md-6">
            <div class="p-4 bg-dark text-white rounded shadow h-100" style="border: 2px solid #c0392b;">
                <h2 class="fw-bold mb-4 text-white">Send Us a Message</h2>

                <!-- Success Message -->
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["SuccessMessage"]
                    </div>
                }

                <!-- Enquiry Form -->
                <form asp-controller="Enquiries" asp-action="Create" method="post">
                    <div class="mb-3">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="name" name="Name" placeholder="Enter your full name" required>
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="phone" name="PhoneNumber" placeholder="Enter your phone number" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email Address</label>
                        <input type="email" class="form-control" id="email" name="Email" placeholder="Enter your email" required>
                    </div>
                    <div class="mb-3">
                        <label for="message" class="form-label">Message</label>
                        <textarea class="form-control" id="message" name="Message" rows="5" placeholder="Write your message here" required></textarea>
                    </div>

                    <!-- Hidden Fields -->
                    <input type="hidden" name="CardId" value="1" />
                    <input type="hidden" name="DateSubmitted" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")" />

                    <button type="submit" class="btn btn-outline-light btn-lg w-100" style="border-color: #c0392b; color: #c0392b;">Send Message</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Google Map Section -->
    <h2 class="text-center fw-bold text-white mb-4 mt-5">Our Location</h2>
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="map-responsive" style="border: 2px solid #c0392b; border-radius: 10px; overflow: hidden;">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2299.398196397993!2d-7.483196722960448!3d54.80811911435475!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x485fc4a2d0e9ab31%3A0xef00368d07438c00!2sOrchard%20Road%20Industrial%20Estate%2C%20Orchard%20Rd%2C%20Strabane%20BT82%209FR!5e0!3m2!1sen!2suk!4v1734913630830!5m2!1sen!2suk"
                            width="100%"
                            height="450"
                            frameborder="0"
                            style="border: 0;"
                            allowfullscreen=""
                            aria-hidden="false"
                            tabindex="0">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>
